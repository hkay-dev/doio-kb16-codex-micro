<Window x:Class="Doio.Kb16.Mapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DOIO KB16 Codex Mapper" Width="1180" Height="760" MinWidth="980" MinHeight="650"
        Icon="Assets/Doio.Kb16.Mapper.png" ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen" SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <Style x:Key="LayerTabStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Margin="2">
                            <Border x:Name="TabSurface" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="FocusRing" CornerRadius="8" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-1" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="TabSurface" Property="Background" Value="{StaticResource ControlBrush}"/><Setter Property="Foreground" Value="{StaticResource InkBrush}"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LayerTabsStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{TemplateBinding Background}" CornerRadius="9" Padding="3">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemsPanel">
                <Setter.Value><ItemsPanelTemplate><StackPanel Orientation="Horizontal" IsItemsHost="True"/></ItemsPanelTemplate></Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource ShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="DraftRow" Height="68"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Panel.ZIndex="2">
            <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="3" Direction="270" Color="#B7A792" Opacity="0.24"/></Border.Effect>
            <Grid x:Name="TopBarGrid" Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="BrandColumn" Width="278"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/Doio.Kb16.Mapper.png" Width="34" Height="34" Stretch="UniformToFill"/>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DOIO KB16 Codex Mapper" FontSize="15" FontWeight="Bold"/>
                        <TextBlock x:Name="BrandSubtitle" Text="四层键位与原生 Codex 控件" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse x:Name="ConnectionLed" Width="12" Height="12" Fill="#AAA9A1" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="尚未连接设备" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ConfigMetaText" Foreground="{StaticResource MutedBrush}" FontFamily="{StaticResource MonoFont}" FontSize="10" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="LightingButton" Width="42" Height="42" Margin="0,0,4,0" BorderThickness="0" Background="Transparent"
                            ToolTip="普通层灯光 · 设备未连接" AutomationProperties.Name="普通层灯光" IsEnabled="False" Click="LightingButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Margin="5">
                                    <Ellipse x:Name="LightingSurface" Fill="{Binding Content.Fill, RelativeSource={RelativeSource TemplatedParent}}" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Ellipse.RenderTransform>
                                        <Ellipse.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="315" Color="#B1A18C" Opacity="0.34"/></Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="LightingSurface" Property="Opacity" Value="0.86"/></Trigger>
                                    <Trigger Property="IsPressed" Value="True"><Setter TargetName="LightingSurface" Property="Effect" Value="{x:Null}"/><Setter TargetName="LightingSurface" Property="Opacity" Value="0.72"/></Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="LightingSurface" Property="Opacity" Value="0.9"/>
                                        <Setter TargetName="LightingSurface" Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1.08" ScaleY="1.08"/></Setter.Value></Setter>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.38"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Ellipse x:Name="LightingIndicator" Fill="#8E8D86" IsHitTestVisible="False"/>
                    </Button>
                    <Button x:Name="ReadButton" Content="连接 / 读取" Style="{StaticResource SoftButtonStyle}" Click="ReadDevice_Click"/>
                    <Button x:Name="MoreButton" Content="•••" ToolTip="更多操作" Style="{StaticResource IconButtonStyle}" Click="More_Click">
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom">
                                <MenuItem Header="导入 JSON" Click="Import_Click"/>
                                <MenuItem Header="导出 JSON" Click="Export_Click"/>
                                <Separator/>
                                <MenuItem Header="恢复 v1.2 默认" Foreground="{StaticResource DangerBrush}" Click="Reset_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Popup x:Name="LightingPopup" PlacementTarget="{Binding ElementName=LightingButton}"
               AllowsTransparency="True" PopupAnimation="Fade" Placement="Custom"
               CustomPopupPlacementCallback="LightingPopup_Placement"
               StaysOpen="False" Closed="LightingPopup_Closed">
            <Border x:Name="LightingPanel" Width="326" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18,16,18,14"
                    KeyboardNavigation.TabNavigation="Cycle" PreviewKeyDown="LightingPanel_PreviewKeyDown">
                <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="3" Direction="315" Color="#B1A18C" Opacity="0.34"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="普通层灯光" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="数字、导航、系统三层共用" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="34" Height="34" CornerRadius="17" Background="#6C72C8" x:Name="LightingColorPreview">
                            <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="315" Color="#B1A18C" Opacity="0.28"/></Border.Effect>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <Grid><TextBlock Text="亮度" FontWeight="SemiBold"/><TextBlock x:Name="BrightnessValueText" Text="47%" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontFamily="{StaticResource MonoFont}"/></Grid>
                        <Slider x:Name="BrightnessSlider" Minimum="0" Maximum="100" Value="47" SmallChange="1" LargeChange="5"
                                AutomationProperties.Name="亮度" Style="{StaticResource LightingSliderStyle}" ValueChanged="LightingSlider_ValueChanged" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Grid><TextBlock Text="色相" FontWeight="SemiBold"/><TextBlock x:Name="HueValueText" Text="239°" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontFamily="{StaticResource MonoFont}"/></Grid>
                        <Slider x:Name="HueSlider" Minimum="0" Maximum="359" Value="239" SmallChange="1" LargeChange="10"
                                AutomationProperties.Name="色相" Style="{StaticResource LightingSliderStyle}" ValueChanged="LightingSlider_ValueChanged" Margin="0,5,0,0">
                            <Slider.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#E85D4A" Offset="0"/><GradientStop Color="#F2D34B" Offset="0.167"/>
                                    <GradientStop Color="#69BD68" Offset="0.333"/><GradientStop Color="#4CBFC4" Offset="0.5"/>
                                    <GradientStop Color="#617BCB" Offset="0.667"/><GradientStop Color="#C264AD" Offset="0.833"/>
                                    <GradientStop Color="#E85D4A" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <Grid><TextBlock Text="饱和度" FontWeight="SemiBold"/><TextBlock x:Name="SaturationValueText" Text="55%" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontFamily="{StaticResource MonoFont}"/></Grid>
                        <Slider x:Name="SaturationSlider" Minimum="0" Maximum="100" Value="55" SmallChange="1" LargeChange="5"
                                AutomationProperties.Name="饱和度" Style="{StaticResource LightingSliderStyle}" ValueChanged="LightingSlider_ValueChanged" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border x:Name="LightingError" Grid.Row="4" Margin="0,12,0,0" Padding="10,8" CornerRadius="7"
                            Background="#16B42318" Visibility="Collapsed">
                        <TextBlock x:Name="LightingErrorText" Foreground="#9D3515" FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <Grid Grid.Row="5" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="拖动时实时预览" Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="取消" Width="82" Style="{StaticResource SoftButtonStyle}" Click="CancelLighting_Click"/>
                        <Button x:Name="SaveLightingButton" Grid.Column="2" Content="保存灯光" Width="112" MinWidth="112" Style="{StaticResource PrimaryButtonStyle}" Click="SaveLighting_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Popup>

        <Grid x:Name="ConnectedWorkspace" Grid.Row="1" Margin="14" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.62*"/>
                <ColumnDefinition x:Name="MainGapColumn" Width="14"/>
                <ColumnDefinition Width="0.78*" MinWidth="286"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10">
                <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="315" Color="#B7A792" Opacity="0.23"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition x:Name="WorkspaceHeaderRow" Height="54"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="14,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TabControl x:Name="LayerTabs" SelectedIndex="0" Style="{StaticResource LayerTabsStyle}" ItemContainerStyle="{StaticResource LayerTabStyle}"
                                    SelectionChanged="LayerTabs_SelectionChanged" VerticalAlignment="Center">
                            <TabItem Header="CODEX"/><TabItem Header="数字"/><TabItem Header="导航"/><TabItem Header="系统"/>
                        </TabControl>
                        <TextBlock x:Name="LayerNote" Grid.Column="1" Text="CODEX 层  16 个按键  3 个旋钮" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Border Grid.Row="1" x:Name="DeviceStage" Padding="18,14,18,12">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="#EEEDE8" Geometry="M0,0 H20 V20 H0 Z">
                                        <GeometryDrawing.Pen><Pen Brush="#0A4B4A44" Thickness="1"/></GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                        <Border x:Name="HardwareShell" MaxWidth="690" Padding="14" CornerRadius="18">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#F7F6F1"/><GradientStop Color="#DFDED8" Offset="1"/></LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="3" Direction="315" Color="#B1A18C" Opacity="0.27"/></Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition x:Name="EncoderRow" Height="116"/></Grid.RowDefinitions>
                                <UniformGrid x:Name="KeyboardGrid" Rows="4" Columns="4"/>
                                <UniformGrid x:Name="EncoderGrid" Grid.Row="1" Rows="1" Columns="3" Margin="0,10,0,0"/>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10">
                <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="315" Color="#B7A792" Opacity="0.23"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel x:Name="EditorHeader" Margin="16,14,16,10">
                        <TextBlock x:Name="EditorTitle" Text="编辑所选控件" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="SelectedControlText" Text="请选择按键或旋钮动作" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                        <Border Background="{StaticResource ControlBrush}" CornerRadius="8" Padding="12,9" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="当前草稿" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="CurrentActionText" Text="—" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="CurrentDraftMark" Grid.Column="1" Text="" Foreground="#8D3B0B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="FilterPanel" Grid.Row="1" Margin="13,0,13,8">
                        <Grid>
                            <TextBox x:Name="SearchBox" ToolTip="搜索动作或按键" TextChanged="Filter_Changed"/>
                            <TextBlock x:Name="SearchWatermark" Text="搜索动作或按键" Foreground="#8A8982" Margin="15,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                        <WrapPanel Margin="0,5,0,0">
                            <RadioButton x:Name="CategoryAll" Content="全部" Tag="全部" GroupName="ActionCategory" IsChecked="True" Style="{StaticResource ChipStyle}" Click="Category_Click"/>
                            <RadioButton Content="键盘" Tag="键盘" GroupName="ActionCategory" Style="{StaticResource ChipStyle}" Click="Category_Click"/>
                            <RadioButton Content="媒体" Tag="媒体" GroupName="ActionCategory" Style="{StaticResource ChipStyle}" Click="Category_Click"/>
                            <RadioButton Content="鼠标" Tag="鼠标" GroupName="ActionCategory" Style="{StaticResource ChipStyle}" Click="Category_Click"/>
                            <RadioButton Content="设备" Tag="设备" GroupName="ActionCategory" Style="{StaticResource ChipStyle}" Click="Category_Click"/>
                        </WrapPanel>
                    </StackPanel>
                    <ListBox x:Name="ActionBox" Grid.Row="2" Style="{StaticResource ActionListStyle}" ItemContainerStyle="{StaticResource ActionItemStyle}"
                             SelectionChanged="ActionBox_SelectionChanged" Margin="8,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CodeText}" Foreground="{StaticResource MutedBrush}" FontFamily="{StaticResource MonoFont}" FontSize="9"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel x:Name="ModifierPanel" Grid.Row="3" Margin="12,8,12,10">
                        <TextBlock Text="组合键修饰符" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                        <UniformGrid Columns="4" Margin="0,4,0,0">
                            <CheckBox x:Name="CtrlBox" Content="Ctrl" Style="{StaticResource ModifierStyle}" Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
                            <CheckBox x:Name="ShiftBox" Content="Shift" Style="{StaticResource ModifierStyle}" Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
                            <CheckBox x:Name="AltBox" Content="Alt" Style="{StaticResource ModifierStyle}" Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
                            <CheckBox x:Name="WinBox" Content="Win" Style="{StaticResource ModifierStyle}" Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
                        </UniformGrid>
                        <TextBlock x:Name="EditorHint" Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="3,4,3,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="EmptyState" Grid.Row="1" Margin="14">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10">
                <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="315" Color="#B7A792" Opacity="0.23"/></Border.Effect>
                <StackPanel Width="560" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="Assets/Doio.Kb16.Mapper.png" Width="72" Height="72" HorizontalAlignment="Center"/>
                    <TextBlock Text="连接你的 DOIO KB16" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,8"/>
                    <TextBlock Text="读取设备后才能编辑四层键位。读取不会修改配置，也不会进入 Bootloader。" Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" LineHeight="22"/>
                    <Button Content="连接并读取" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,16,0,0" Click="ReadDevice_Click"/>
                    <TextBlock Text="支持 DOIO KB16-01 Rev2 / USB 303A:8360" Foreground="{StaticResource MutedBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="InlineError" Grid.Row="1" Background="#F9E7E2" CornerRadius="8" Padding="14,10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0" Visibility="Collapsed" Panel.ZIndex="5">
            <Border.Effect><DropShadowEffect BlurRadius="22" ShadowDepth="3" Direction="270" Color="#B7A18E" Opacity="0.26"/></Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="InlineErrorTitle" Foreground="#7E241B" FontWeight="Bold"/>
                <TextBlock x:Name="InlineErrorMessage" Foreground="#7E241B" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource ControlBrush}" Panel.ZIndex="2">
            <Grid x:Name="DraftBarGrid" Margin="18,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="DraftTitle" Text="等待读取设备" FontSize="14" FontWeight="Bold"/>
                    <TextBlock x:Name="DraftSubtitle" Text="连接后会在这里显示未应用修改和设备快照" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock x:Name="SnapshotText" Grid.Column="1" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource MutedBrush}" FontSize="10" TextAlignment="Right" VerticalAlignment="Center" Margin="20,0"/>
                <Button x:Name="RevertButton" Grid.Column="2" Content="撤销修改" Style="{StaticResource SoftButtonStyle}" Click="Revert_Click" IsEnabled="False"/>
                <Button x:Name="ApplyButton" Grid.Column="3" Content="应用到设备" Style="{StaticResource PrimaryButtonStyle}" Click="Apply_Click" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
