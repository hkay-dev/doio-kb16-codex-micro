<Application x:Class="Doio.Kb16.Mapper.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="CanvasColor">#DEDED8</Color>
        <Color x:Key="ShellColor">#F2F1EC</Color>
        <Color x:Key="SurfaceColor">#F8F7F2</Color>
        <Color x:Key="Surface2Color">#E8E7E1</Color>
        <Color x:Key="ControlColor">#EEEDE8</Color>
        <Color x:Key="InkColor">#242420</Color>
        <Color x:Key="MutedColor">#6D6C65</Color>
        <Color x:Key="AccentColor">#E96E24</Color>
        <Color x:Key="AccentSoftColor">#F7E2D4</Color>
        <Color x:Key="AccentInkColor">#352013</Color>
        <Color x:Key="SuccessColor">#278657</Color>
        <Color x:Key="DangerColor">#A8291E</Color>

        <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}"/>
        <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
        <SolidColorBrush x:Key="ControlBrush" Color="{StaticResource ControlColor}"/>
        <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}"/>
        <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}"/>
        <SolidColorBrush x:Key="AccentInkBrush" Color="{StaticResource AccentInkColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="FocusBrush" Color="#66DC3E1C"/>

        <FontFamily x:Key="UiFont">Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="{StaticResource ShellBrush}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SoftButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="4">
                            <Border x:Name="Outer" Background="{TemplateBinding Background}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="315" Color="#B7A792" Opacity="0.30"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Border x:Name="SoftHighlight" CornerRadius="8" BorderBrush="#70FFFFFF" BorderThickness="1" IsHitTestVisible="False"/>
                            <Border x:Name="FocusRing" CornerRadius="10" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-2" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="SoftHighlight" Property="BorderBrush" Value="#B8FFFFFF"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Outer" Property="Effect" Value="{x:Null}"/><Setter TargetName="SoftHighlight" Property="Opacity" Value="0.35"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SoftButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentInkBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="150"/>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SoftButtonStyle}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="LightingTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LightingThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Margin="2">
                            <Ellipse Fill="#F4F3EE">
                                <Ellipse.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="315" Color="#B5A58F" Opacity="0.34"/></Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Margin="3" Stroke="#9AFFFFFF" StrokeThickness="1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LightingSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="30"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="9" CornerRadius="5" Background="{TemplateBinding Background}" VerticalAlignment="Center">
                                <Border.Effect><DropShadowEffect BlurRadius="7" ShadowDepth="1" Direction="135" Color="#B9AA96" Opacity="0.22"/></Border.Effect>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource LightingTrackButtonStyle}" Command="Slider.DecreaseLarge"/></Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb Style="{StaticResource LightingThumbStyle}"/></Track.Thumb>
                                <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource LightingTrackButtonStyle}" Command="Slider.IncreaseLarge"/></Track.IncreaseRepeatButton>
                            </Track>
                            <Border x:Name="SliderFocus" CornerRadius="8" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-2" Visibility="Collapsed" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="SliderFocus" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KeycapButtonStyle" TargetType="Button" BasedOn="{StaticResource SoftButtonStyle}">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="EncoderActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="MinHeight" Value="54"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="1">
                            <ContentPresenter x:Name="ActionText" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            <Border x:Name="FocusRing" CornerRadius="7" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ActionText" Property="Opacity" Value="0.72"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ActionText" Property="Opacity" Value="0.48"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.38"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KnobButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Background" Value="#ECEBE6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="4">
                            <Ellipse Fill="#E4E2DC"/>
                            <Ellipse x:Name="Disk" Margin="6" Fill="{TemplateBinding Background}">
                                <Ellipse.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="315" Color="#B5A58F" Opacity="0.28"/></Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Width="5" Height="5" Fill="#D2CFC7" VerticalAlignment="Top" Margin="0,14,0,0"/>
                            <Ellipse Margin="8" Stroke="#66FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
                            <Ellipse x:Name="KnobFocus" Stroke="{StaticResource FocusBrush}" StrokeThickness="3" Margin="-2" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Disk" Property="Fill" Value="#DFDED8"/><Setter TargetName="Disk" Property="Effect" Value="{x:Null}"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="KnobFocus" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.42"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Margin="1">
                            <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="13" Padding="{TemplateBinding Padding}">
                                <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="315" Color="#B9AA96" Opacity="0.28"/></Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="FocusRing" CornerRadius="15" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-2" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="Surface" Property="Background" Value="#E2E1DB"/><Setter Property="Foreground" Value="{StaticResource InkBrush}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter TargetName="Surface" Property="Effect" Value="{x:Null}"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModifierStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Margin="4">
                            <Border x:Name="Key" Height="36" Background="{TemplateBinding Background}" CornerRadius="7">
                                <Border.Effect><DropShadowEffect BlurRadius="11" ShadowDepth="2" Direction="315" Color="#B9AA96" Opacity="0.30"/></Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="FocusRing" CornerRadius="9" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-2" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="Key" Property="Background" Value="#DEDDD7"/><Setter TargetName="Key" Property="Effect" Value="{x:Null}"/><Setter Property="FontWeight" Value="SemiBold"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.42"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid Margin="3">
                            <Border x:Name="Input" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Border x:Name="FocusRing" CornerRadius="10" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-2" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="ActionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="4,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="ItemSurface" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <Border x:Name="FocusRing" CornerRadius="9" BorderBrush="{StaticResource FocusBrush}" BorderThickness="3" Margin="-1" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#EEEDE8"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource AccentSoftBrush}"/><Setter Property="Foreground" Value="#8D3B0B"/><Setter Property="FontWeight" Value="SemiBold"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusRing" Property="Visibility" Value="Visible"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#FAF9F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
    </Application.Resources>
</Application>
